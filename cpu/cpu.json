{
  "apiVersion": "jobset.x-k8s.io/v1alpha2",
  "kind": "JobSet",
  "metadata": {
    "name": "axlearn-cpu-unit-tests",
    "annotations": {
      "kueue.x-k8s.io/queue-name": "cpu-worker"
    },
    "ownerReferences": [
        {
            "apiVersion": "v1",
            "kind": "Pod",
            "name": "POD_NAME_HERE",
            "uid": "UID_HERE"
        }
    ]
  },
  "spec": {
    "failurePolicy": {
      "maxRestarts": 3
    },
    "replicatedJobs": [
      {
        "name": "job",
        "replicas": 1,
        "template": {
          "spec": {
            "parallelism": 1,
            "completions": 1,
            "backoffLimit": 0,
            "template": {
              "metadata": {
                "annotations": {
                  "kubectl.kubernetes.io/default-container": "axlearn-cpu-unit-tests"
                }
              },
              "spec": {
                "terminationGracePeriodSeconds": 60,
                "restartPolicy": "Never",
                "initContainers": [],
                "hostNetwork": true,
                "dnsPolicy": "ClusterFirstWithHostNet",
                "containers": [
                  {
                    "name": "axlearn-cpu-unit-tests",
                    "image": "INSERT_DOCKER_IMAGE",
                    "securityContext": {
                      "privileged": true
                    },
                    "command": [
                      "bash",
                      "/var/arc/cpu-jobset-startup.sh"
                    ],
                    "env": [
                      {
                        "name": "NUM_PROCESSES",
                        "value": "1"
                      },
                      {
                        "name": "PROCESS_ID",
                        "valueFrom": {
                          "fieldRef": {
                            "fieldPath": "metadata.annotations['batch.kubernetes.io/job-completion-index']"
                          }
                        }
                      },
                      {
                        "name": "GCS_PREFIX",
                        "value": "INSERT_GCS_PREFIX"
                      },
                      {
                        "name": "CUSTOM_GIT_ORIGIN",
                        "value": "INSERT_GIT_ORIGIN"
                      },
                      {
                        "name": "CUSTOM_GIT_BRANCH",
                        "value": "INSERT_GIT_BRANCH"
                      }
                    ]
                  }
                ],
                "serviceAccountName": "default"
              }
            }
          }
        }
      }
    ]
  }
}